{
  "name": "@repo/database",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "npm run prisma:studio",
    "prisma:generate": "dotenv -e ../../.env -- prisma generate",
    "prisma:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "prisma:studio": "dotenv -e ../../.env -- prisma studio --browser none",
    "seed": "dotenv -e ../../.env -- tsx src/seed.ts",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.16.1"
  },
  "devDependencies": {
    "@repo/eslint-config": "*",
    "@repo/typescript-config": "*",
    "@repo/types": "*",
    "@types/node": "^22.15.3",
    "eslint": "^9.39.1",
    "prisma": "^6.16.1",
    "tsx": "^4.19.2",
    "typescript": "5.9.2"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  }
}
